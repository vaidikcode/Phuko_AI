# ── LLM Provider ─────────────────────────────────────────────────────────────
# Switch between "gemini" (cloud) and "ollama" (local)
LLM_PROVIDER=gemini

# Gemini (default) — get key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Ollama (local) — install from https://ollama.com, then: ollama pull qwen2.5:7b-instruct
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct

# ── Database (libSQL + Drizzle: rules, runs, memories, suggestions, calendar) ──
# Local dev (fully offline, no cloud needed):
DATABASE_URL=file:./phuko.db
# Turso cloud (optional, zero code change required):
# DATABASE_URL=libsql://your-db-name.turso.io
# DATABASE_AUTH_TOKEN=your_turso_auth_token_here

# ── Cron ─────────────────────────────────────────────────────────────────────
# Set to "true" to enable automatic hourly + daily cron jobs
CRON_ENABLED=true
# Optional: IANA timezone so Node’s “local calendar day” matches your life (hourly full-day scan + libSQL server)
# TZ=America/Los_Angeles


# ── UI ───────────────────────────────────────────────────────────────────────
# Shows the provider name in the sidebar (client-side)
NEXT_PUBLIC_LLM_PROVIDER=gemini
